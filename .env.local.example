# ─── Spring Boot API URL ─────────────────────────────────────────────────
# Dev: localhost.
MAGENC_API_URL=http://localhost:8080

# ─── Cookie domain scope ─────────────────────────────────────────────────
# Leave empty in dev — cookies will be host-only on localhost.
# In prod: .orchestrate.marketing (leading dot = shared across subdomains).
MAGENC_COOKIE_DOMAIN=

# ─── Node environment ────────────────────────────────────────────────────
# Next.js sets this automatically but can override here if needed.
NODE_ENV=development
